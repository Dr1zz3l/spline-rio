<?xml version="1.0"?>
<!-- ekf_rio on OUR converted bags (baselines/datasets/our_bags/*_rio.bag).
     Run inside the rio-baselines docker image:
       roslaunch /workspace/baselines/configs/our_bags_ekf-rio_rosbag.launch \
         rosbag:=slow_racing_best_velocity_rio.bag \
         out_bag:=/workspace/baselines/results/slow_racing_ekf_rio.bag -->

<launch>
    <arg name="do_plot" default="False"/>
    <param name="use_sim_time" value="False" type="bool"/>

    <arg name="dataset_dir" default="/workspace/baselines/datasets/our_bags"/>
    <arg name="rosbag"/>
    <arg name="out_bag"/>

    <arg name="config" default="/workspace/baselines/configs/ekf_rio_our_platform.yaml"/>
    <arg name="calibration" default="/workspace/baselines/configs/calib_our_platform.yaml"/>

    <arg name="bag_start" default="0"/>
    <arg name="bag_duration" default="-1.0"/>
    <arg name="sleep_ms" default="10"/>
    <arg name="filter_node_name" default="ekf_rio"/>
    <arg name="log_level" default="Info"/>

    <node name="$(arg filter_node_name)" pkg="ekf_rio" type="rosbag_node" output="screen" launch-prefix="bash -c 'sleep 4; $0 $@' ">
        <rosparam file="$(arg config)" command="load" ns=""/>
        <rosparam file="$(arg calibration)" command="load" ns=""/>
        <param name="rosbag_path" value="$(arg dataset_dir)/$(arg rosbag)" type="string"/>
        <param name="bag_start" value="$(arg bag_start)" type="double"/>
        <param name="bag_duration" value="$(arg bag_duration)" type="double"/>
        <param name="sleep_ms" value="$(arg sleep_ms)" type="double"/>
        <param name="republish_ground_truth" value="true" type="bool"/>
        <param name="run_without_radar_trigger" value="true" type="bool"/>
    </node>

    <!-- record the estimate for offline evaluation through our analysis code -->
    <node name="recorder" pkg="rosbag" type="record"
          args="record -O $(arg out_bag) /$(arg filter_node_name)/pose /$(arg filter_node_name)/twist /$(arg filter_node_name)/state /ground_truth/pose /ground_truth/twist"/>

    <!-- their evaluator for a cross-check of our offline metrics -->
    <node name="evaluator" pkg="ekf_rio" type="pose_velocity_evaluator.py" output="screen">
        <rosparam file="$(arg calibration)" command="load" ns=""/>
        <param name="topic_pose" value="$(arg filter_node_name)/pose" type="string"/>
        <param name="topic_twist" value="$(arg filter_node_name)/twist" type="string"/>
        <param name="filter_name" value="ekf_rio" type="string"/>
        <param name="do_plot" value="$(arg do_plot)" type="bool"/>
    </node>
</launch>
